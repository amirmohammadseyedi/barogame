POSTGRES_DB=arocr
POSTGRES_USER=arocr
POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me-in-production
DEBUG=True

# پورت مستقیم بک‌اند (بدون nginx) — مثلاً http://194.5.192.244:8081
WEB_EXPOSE_PORT=8081

# آدرس عمومی بک‌اند (بدون / آخر) — host این آدرس هم به ALLOWED_HOSTS اضافه می‌شود
BACKEND_BASE_DOMAIN=http://localhost:8000

# روی سرور — فرمت درست (با http/https، بدون / آخر):
# BACKEND_BASE_DOMAIN=https://arobus.net
# ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,arobus.net,194.5.192.244
# CSRF_TRUSTED_ORIGINS=https://arobus.net,http://194.5.192.244:8081
# CORS_ALLOWED_ORIGINS=https://arobus.net,http://194.5.192.244:8081
ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:13082,http://127.0.0.1:13082
CORS_ALLOWED_ORIGINS=http://localhost:13082,http://127.0.0.1:13082
